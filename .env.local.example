# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Mapbox access token (get from https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Secret token for Overland app authentication (generate a random string)
OVERLAND_TOKEN=your-secret-token-here

# Home location — GPS points within HOME_RADIUS_METERS of this point are
# excluded from the map, stats, and street-matching pipeline. Unset to
# disable. Radius defaults to 100m. Tune based on how much sprawl your
# indoor scribble covers.
HOME_LAT=40.6782
HOME_LNG=-73.9442
HOME_RADIUS_METERS=100
